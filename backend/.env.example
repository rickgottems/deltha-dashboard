# Copie para .env e ajuste. Instruções completas no README.md
DATABASE_URL="file:./deltha.db"
PORT=3001
FRONTEND_URL=http://localhost:5173

# Interface de rede em que a API escuta. Sem HOST definido, escuta em todas as
# interfaces (0.0.0.0) — necessário para a equipe do escritório acessar de suas
# próprias máquinas apontando para o IP do servidor. A API NÃO tem autenticação
# (usuário único local, ver README) — se este servidor estiver numa rede
# compartilhada com máquinas não confiáveis, considere HOST=127.0.0.1 (só a
# própria máquina acessa) e usar um proxy/túnel autenticado na frente para os
# demais usuários.
# HOST=127.0.0.1

# Google Calendar (opcional — a aba Calendário funciona sem isto)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3001/api/calendar/callback

# Importação automática de NF-e (opcional). Pasta onde o robô SIEG salva os
# XMLs desta empresa (varredura recursiva — pode apontar para "01-Apurações"
# para pegar todos os meses de uma vez). Ver README seção "Importação automática".
# NFE_IMPORT_DIR=E:\FISCAL\NOME_EMPRESA\2026\01-Apurações
