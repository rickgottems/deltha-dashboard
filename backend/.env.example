# Copie para .env e ajuste. Instruções completas no README.md
DATABASE_URL="postgresql://user:password@localhost:5432/deltha"
PORT=3001
FRONTEND_URL=http://localhost:5173

# Obrigatório — assina as sessões de login (JWT). Gere um valor aleatório
# forte, ex.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# NUNCA reutilize o mesmo valor entre ambientes (dev/produção).
JWT_SECRET=troque-este-valor-por-um-segredo-aleatorio-forte

# Interface de rede em que a API escuta. Sem HOST definido, escuta em todas as
# interfaces (0.0.0.0). Toda rota /api/* (exceto /api/health e /api/auth/*)
# exige sessão válida — ver src/lib/auth-middleware.ts.
# HOST=127.0.0.1

# Google Calendar (opcional — a aba Calendário funciona sem isto)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3001/api/calendar/callback

# Importação automática de NF-e (opcional, uso via `npm run import:nfe`).
# Pasta onde o robô SIEG salva os XMLs (varredura recursiva). Ver README
# seção "Importação automática". A empresa de destino é identificada pelo
# e-mail de login em NFE_IMPORT_COMPANY_EMAIL (ou 2º argumento do comando).
# NFE_IMPORT_DIR=E:\FISCAL\NOME_EMPRESA\2026\01-Apurações
# NFE_IMPORT_COMPANY_EMAIL=empresa@exemplo.com.br
