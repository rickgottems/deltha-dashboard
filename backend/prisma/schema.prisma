// ============================================================
// Deltha Dashboard — Schema do banco de dados
//
// Multiempresa (SaaS): cada empresa que se cadastra é uma `Company`,
// isolada das demais — toda tabela de negócio carrega `companyId` e é
// sempre filtrada por ele nas rotas (ver backend/src/lib/auth-middleware.ts).
// `accountType` distingue Cliente Deltha (dados chegam via importação
// automática de NF-e) de Externo (lança tudo manualmente) — ver Fase B.
//
// Banco: PostgreSQL (Railway). Migrado de SQLite em 2026-07 para suportar
// escrita concorrente de várias empresas ao mesmo tempo.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  // Único quando presente (Postgres permite múltiplos NULL numa coluna @unique
  // — por isso continua nullable no schema mesmo sendo obrigatório na API de
  // cadastro, ver routes/auth.ts: assim uma mudança de regra de negócio não
  // exige migration destrutiva). Guardado só como dígitos (sem máscara).
  cnpj        String?  @unique
  // DELTHA_CLIENT | EXTERNO (ver src/lib/constants.ts) — Fase B ativa o uso real disso na UI
  accountType String   @default("EXTERNO")
  createdAt   DateTime @default(now()) @map("created_at")

  users               User[]
  clients             Client[]
  receivables         Receivable[]
  expenses            Expense[]
  products            Product[]
  sellers             Seller[]
  sales               Sale[]
  teams               Team[]
  tasks               Task[]
  goals               Goal[]
  alertThresholds     AlertThreshold[]
  integrationTokens   IntegrationToken[]
  importedDocuments   ImportedDocument[]
  balanceSheets       BalanceSheet[]
  cashFlowStatements  CashFlowStatement[]
  apiKeys             ApiKey[]

  @@map("companies")
}

model User {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([companyId])
  @@map("users")
}

model Client {
  id          String       @id @default(cuid())
  companyId   String       @map("company_id")
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  email       String?
  phone       String?
  // CNPJ do destinatário — chave de upsert para clientes vindos de importação de NF-e.
  // Único POR EMPRESA (duas empresas-cliente podem ambas ter o mesmo CNPJ como cliente delas).
  cnpj        String?
  createdAt   DateTime     @default(now()) @map("created_at")
  receivables Receivable[]
  sales       Sale[]

  @@unique([companyId, cnpj])
  @@index([companyId])
  @@map("clients")
}

// Receitas / contas a receber. Também é o HISTÓRICO DE COBRANÇAS usado
// pelo score de risco de inadimplência (client_id, due_date, paid_date, amount, status).
model Receivable {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId    String?   @map("client_id")
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  description String?
  category    String    @default("Geral")
  amount      Float
  dueDate     DateTime  @map("due_date")
  paidDate    DateTime? @map("paid_date")
  // PENDENTE | PAGA | ATRASADA | CANCELADA  (ver src/lib/constants.ts)
  status      String    @default("PENDENTE")
  // MANUAL | NFE | DOMINIO — origem do lançamento (ver RECORD_SOURCES)
  source      String    @default("MANUAL")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([companyId, dueDate])
  @@index([clientId])
  @@map("receivables")
}

model Expense {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category    String   @default("Geral")
  // Classificação DRE: DEDUCAO | CUSTO | OPERACIONAL | DEPRECIACAO | FINANCEIRA | OUTRA
  // Usada no waterfall (Receita Bruta → ... → Lucro Operacional) e no EBITDA.
  kind        String   @default("OPERACIONAL")
  description String?
  amount      Float
  date        DateTime
  // MANUAL | NFE | DOMINIO — origem do lançamento (ver RECORD_SOURCES)
  source      String   @default("MANUAL")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([companyId, date])
  @@map("expenses")
}

model Product {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  costPrice Float    @map("cost_price")
  salePrice Float    @map("sale_price")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  sales     Sale[]

  @@index([companyId])
  @@map("products")
}

model Seller {
  id        String  @id @default(cuid())
  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  sales     Sale[]

  @@index([companyId])
  @@map("sellers")
}

model Sale {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId String?  @map("product_id")
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  clientId  String?  @map("client_id")
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  sellerId  String?  @map("seller_id")
  seller    Seller?  @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  quantity  Int      @default(1)
  amount    Float
  date      DateTime
  // MANUAL | NFE | DOMINIO — origem do lançamento (ver RECORD_SOURCES)
  source    String   @default("MANUAL")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([companyId, date])
  @@map("sales")
}

model Team {
  id        String  @id @default(cuid())
  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  tasks     Task[]

  @@index([companyId])
  @@map("teams")
}

model Task {
  id            String    @id @default(cuid())
  companyId     String    @map("company_id")
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  teamId        String?   @map("team_id")
  team          Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  title         String
  dueDate       DateTime  @map("due_date")
  deliveredDate DateTime? @map("delivered_date")
  // EM_ANDAMENTO | CONCLUIDA | CANCELADA
  status        String    @default("EM_ANDAMENTO")
  // Motivo do atraso (gargalo): preenchido quando entregue após o prazo ou vencida
  delayReason   String?   @map("delay_reason")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([companyId, dueDate])
  @@map("tasks")
}

// Regras de alerta configuráveis via UI (Configurações → Alertas).
// direction BELOW: dispara quando o valor fica ABAIXO do limiar (ex: margem).
// direction ABOVE: dispara quando o valor fica ACIMA do limiar (ex: despesas).
model AlertThreshold {
  id              String  @id @default(cuid())
  companyId       String  @map("company_id")
  company         Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  metricKey       String  @map("metric_key")
  label           String
  yellowThreshold Float   @map("yellow_threshold")
  redThreshold    Float   @map("red_threshold")
  direction       String  @default("BELOW")
  unit            String  @default("%")
  // Em quais painéis o alerta aparece: executivo | financeiro | ambos
  scope           String  @default("ambos")

  @@unique([companyId, metricKey])
  @@map("alert_thresholds")
}

// Metas configuráveis via UI (Configurações → Metas).
// period: "YYYY-MM" para meta de um mês específico, ou "default" (vale para todos os meses).
model Goal {
  id        String  @id @default(cuid())
  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  metricKey String  @map("metric_key")
  period    String  @default("default")
  value     Float

  @@unique([companyId, metricKey, period])
  @@map("goals")
}

// Tokens OAuth de integrações externas (Google Calendar) — um por empresa.
model IntegrationToken {
  id           String    @id @default(cuid())
  companyId    String    @map("company_id")
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider     String
  accessToken  String    @map("access_token")
  refreshToken String?   @map("refresh_token")
  expiryDate   DateTime? @map("expiry_date")
  scope        String?
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([companyId, provider])
  @@map("integration_tokens")
}

// Rastreia documentos externos já importados (idempotência/deduplicação), por empresa.
// Cobre tanto NF-e (source=NFE, externalId=chave de acesso de 44 dígitos)
// quanto planilhas do Domínio (source=DOMINIO_EXPENSE, externalId=hash de
// data+valor+descrição por LINHA da planilha — ver services/expenseImport.ts).
model ImportedDocument {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // NFE | DOMINIO_EXPENSE (futuros: NFCE, NFSE, CTE)
  source       String
  // chNFe (NF-e) ou hash SHA-256 da linha (planilha Domínio)
  externalId   String
  // caminho do arquivo de origem (auditoria/depuração)
  filePath     String?
  status       String   @default("IMPORTADO") // IMPORTADO | ERRO
  errorMessage String?
  // ids gerados por este import (json simples, ex: {"saleIds":[...],"receivableIds":[...]})
  createdIds   String?
  importedAt   DateTime @default(now()) @map("imported_at")

  @@unique([companyId, source, externalId])
  @@index([companyId, source])
  @@map("imported_documents")
}

// ============================================================
// Balanço Patrimonial e DFC — LANÇAMENTO MANUAL, um snapshot por
// empresa+mês (period = "YYYY-MM", fim do mês). Nada disso é derivável de
// Receivable/Expense/Sale (não existe "estoque", "dívida" ou "patrimônio
// líquido" em lugar nenhum do resto do schema) — por isso são tabelas
// próprias, editadas em Configurações → Balanço/DFC. Alimentam
// services/healthScore.ts (índices de liquidez/alavancagem/runway que a
// DRE sozinha não calcula). Ver validação da equação contábil
// (Ativo = Passivo + PL) em routes/config.ts ao salvar.
// ============================================================
model BalanceSheet {
  id                 String   @id @default(cuid())
  companyId          String   @map("company_id")
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period             String   // "YYYY-MM"
  currentAssets      Float    @map("current_assets")       // Ativo Circulante
  inventory          Float    @map("inventory")             // Estoques (subconjunto do Ativo Circulante)
  nonCurrentAssets   Float    @map("non_current_assets")    // Ativo Não Circulante
  currentLiabilities Float    @map("current_liabilities")   // Passivo Circulante
  shortTermDebt      Float    @map("short_term_debt")       // Dívida de Curto Prazo
  longTermDebt       Float    @map("long_term_debt")        // Dívida de Longo Prazo
  cashAndEquivalents Float    @map("cash_and_equivalents")  // Caixa e Equivalentes
  equity             Float    // Patrimônio Líquido
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([companyId, period])
  @@map("balance_sheets")
}

model CashFlowStatement {
  id                    String   @id @default(cuid())
  companyId             String   @map("company_id")
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period                String   // "YYYY-MM"
  operatingCashFlow     Float    @map("operating_cash_flow") // Fluxo de Caixa Operacional (FCO) do mês
  capex                 Float    // Investimento em ativo imobilizado/intangível do mês
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([companyId, period])
  @@map("cash_flow_statements")
}

// ============================================================
// Chaves de API — autenticação máquina-a-máquina (ex.: robô local do
// escritório que lê NF-e/planilhas e envia via POST para /api/receitas,
// /api/despesas, /api/vendas etc.), alternativa ao cookie de sessão que só
// existe num navegador logado. A chave em texto puro só existe no momento
// da criação (devolvida uma única vez pela API) — só o hash SHA-256 fica
// salvo. Uma chave tem o MESMO acesso de um usuário logado da empresa
// (isolamento por companyId já vale igual — ver lib/auth-middleware.ts).
// ============================================================
model ApiKey {
  id         String    @id @default(cuid())
  companyId  String    @map("company_id")
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String    // rótulo livre, ex: "Robô NF-e escritório"
  keyHash    String    @unique @map("key_hash")
  // Prefixo (ex: "dk_live_ab12") só pra exibir/identificar na UI sem guardar a chave inteira.
  keyPrefix  String    @map("key_prefix")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  revokedAt  DateTime? @map("revoked_at")

  @@index([companyId])
  @@map("api_keys")
}
